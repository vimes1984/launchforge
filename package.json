{
  "name": "launchforge",
  "version": "1.0.0",
  "description": "Agentic Business Strategy & Launch Dashboard",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "prestart": "npm audit --audit-level=moderate || true",
    "dev": "node --watch server.js",
    "health": "curl -s http://localhost:5000/api/health | head -c 200",
    "status": "curl -s http://localhost:5000/api/status | head -c 500",
    "security:audit": "npm audit --audit-level=moderate",
    "security:outdated": "npm outdated --long",
    "security:ci": "npm audit --audit-level=high || true"
  },
  "dependencies": {
    "cors": "2.8.5",
    "express": "4.19.2",
    "express-rate-limit": "8.6.0",
    "helmet": "8.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
