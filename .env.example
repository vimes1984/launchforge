# LaunchForge Configuration
# Copy to .env and fill in values

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=

# Security
# Set to "true" to require Bearer token authentication for /api/chat
REQUIRE_AUTH=false

# Server
PORT=5000
# Custom temp directory for cloned repos (defaults to system temp)
TEMP_DIR=/tmp/launchforge
